{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "ListBucketAtPublicPrefix",
        "Effect": "Allow",
        "Action": ["s3:ListBucket"],
        "Resource": "arn:aws:s3:::dms-s3-parquet-target-v1",
        "Condition": {
          "StringLike": {
            "s3:prefix": ["public/*"]
          }
        }
      },
      {
        "Sid": "ReadObjects",
        "Effect": "Allow",
        "Action": ["s3:GetObject"],
        "Resource": "arn:aws:s3:::dms-s3-parquet-target-v1/public/*"
      }
    ]
  }